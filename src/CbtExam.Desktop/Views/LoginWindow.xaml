<Window x:Class="CbtExam.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels"
        Title="CBT Exam System - Admin Login" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Premium Animated Background Gradient -->
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#09090B" Offset="0.0"/>
            <GradientStop Color="#18181B" Offset="0.4"/>
            <GradientStop Color="#064E3B" Offset="0.8"/>
            <GradientStop Color="#022C22" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="InputFieldStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#10B981"/>
                                <Setter Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordFieldStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#10B981"/>
                                <Setter Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#059669"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3F3F46"/>
                                <Setter Property="Cursor" Value="Wait"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Canvas Opacity="0.4">
            <!-- Glowing orbs -->
            <Ellipse Fill="#059669" Width="300" Height="300" Canvas.Left="-100" Canvas.Top="-50">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#0284C7" Width="400" Height="400" Canvas.Right="-150" Canvas.Bottom="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="200"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- Glassmorphism Card -->
        <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#1AFFFFFF" CornerRadius="20" BorderThickness="1" BorderBrush="#2AFFFFFF">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.4" ShadowDepth="10"/>
            </Border.Effect>

            <Grid Margin="45,55">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,35">
                    <Border Width="90" Height="90" CornerRadius="45" Background="White" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Color="#10B981" Opacity="0.3"/>
                        </Border.Effect>
                        <!-- FallbackValue properly sets the logo to jamb.png! -->
                        <Image Stretch="UniformToFill" Margin="22" 
                               Source="{Binding SchoolLogoPath, TargetNullValue='pack://application:,,,/res/jamb.png', FallbackValue='pack://application:,,,/res/jamb.png'}">
                        </Image>
                    </Border>
                    
                    <TextBlock Text="CBT Exam System" FontSize="28" FontWeight="SemiBold" 
                               Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="Secure Administrator Portal" FontSize="14"
                               Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Error Message -->
                <Border Grid.Row="1" Background="#3E1C1C" CornerRadius="8" Padding="12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                        BorderBrush="#EF4444" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="#FCA5A5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="13" TextWrapping="Wrap"
                                   Foreground="#FECACA" VerticalAlignment="Center" Width="300"/>
                    </StackPanel>
                </Border>

                <!-- Fields -->
                <StackPanel Grid.Row="2" Visibility="Visible">
                    <!-- Username Field -->
                    <TextBlock Text="Username" Foreground="#E4E4E7" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameTextBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource InputFieldStyle}" Margin="0,0,0,20"/>

                    <!-- Password/Access Code Field -->
                    <TextBlock Text="Access Code" Foreground="#E4E4E7" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="CodeBox" PasswordChanged="PasswordBox_PasswordChanged"
                                 Style="{StaticResource PasswordFieldStyle}" Margin="0,0,0,20"/>

                    <CheckBox Content="Remember my credentials" IsChecked="{Binding RememberMe}"
                              Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Login Button -->
                <Button Grid.Row="3" Content="Access Admin" 
                        Style="{StaticResource LoginButtonStyle}"
                        Command="{Binding LoginCommand}"
                        Margin="0,25,0,0"/>
            </Grid>
        </Border>

        <!-- Close Button -->
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                Background="Transparent" BorderThickness="0" Foreground="#A1A1AA"
                FontSize="16" Width="40" Height="40" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15"
                Click="CloseButton_Click" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
