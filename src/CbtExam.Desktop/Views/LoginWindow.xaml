<Window x:Class="CbtExam.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels"
        Title="CBT Mock Exam System - Admin Login" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/Resources/appicon.ico"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Premium Theme Palette -->
        <SolidColorBrush x:Key="PaneBg" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSub" Color="#94A3B8"/>
        <SolidColorBrush x:Key="FieldBg" Color="#0F172A"/>
        <SolidColorBrush x:Key="FieldBorder" Color="#334155"/>
        <SolidColorBrush x:Key="FieldFg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        
        <Style x:Key="InputFieldStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource FieldFg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource FieldFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="45,14,14,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource FieldBorder}"
                                    BorderThickness="1.5" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="FieldShadow" BlurRadius="0" ShadowDepth="0" Color="#3B82F6" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ActiveBorder" BorderBrush="#3B82F6" BorderThickness="1.5" CornerRadius="12" Opacity="0"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActiveBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ActiveBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="FieldShadow" Property="BlurRadius" Value="12"/>
                                <Setter TargetName="FieldShadow" Property="Opacity" Value="0.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordFieldStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource FieldFg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource FieldFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="45,14,45,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource FieldBorder}"
                                    BorderThickness="1.5" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="FieldShadow" BlurRadius="0" ShadowDepth="0" Color="#3B82F6" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ActiveBorder" BorderBrush="#3B82F6" BorderThickness="1.5" CornerRadius="12" Opacity="0"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActiveBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ActiveBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="FieldShadow" Property="BlurRadius" Value="12"/>
                                <Setter TargetName="FieldShadow" Property="Opacity" Value="0.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="54"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="bdBase" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#1D4ED8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="btnShadow" BlurRadius="15" ShadowDepth="4" Color="#3B82F6" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="bdHover" CornerRadius="12" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#2563EB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdHover" Property="Opacity" Value="1"/>
                                <Setter TargetName="btnShadow" Property="BlurRadius" Value="20"/>
                                <Setter TargetName="btnShadow" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnScale" Property="ScaleX" Value="0.98"/>
                                <Setter TargetName="btnScale" Property="ScaleY" Value="0.98"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                <Setter TargetName="bdBase" Property="Background" Value="#334155"/>
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container -->
    <Border Background="#0F172A" CornerRadius="24" BorderThickness="1" BorderBrush="#1E293B" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" Color="Black" Opacity="0.4" ShadowDepth="10"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="460"/>
            </Grid.ColumnDefinitions>

            <!-- Left Pane (Animated Branding) -->
            <Grid Grid.Column="0">
                <Canvas Opacity="0.4" ClipToBounds="True">
                    <!-- Dynamic Background Blobs -->
                    <Ellipse Width="400" Height="400" Fill="#1E3A8A" Opacity="0.1" Canvas.Left="-100" Canvas.Top="-100">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="-100" To="200" Duration="0:0:30" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    
                    <Ellipse Width="300" Height="300" Fill="#1E40AF" Opacity="0.1" Canvas.Right="-50" Canvas.Bottom="-50">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="400" To="100" Duration="0:0:25" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Canvas>
                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60,0">
                    <Border Width="120" Height="120" CornerRadius="30" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,40" HorizontalAlignment="Center">
                        <Image Source="{Binding SchoolLogoImage, TargetNullValue='pack://application:,,,/Resources/jamb.png', FallbackValue='pack://application:,,,/Resources/jamb.png'}" 
                               Stretch="Uniform" Margin="24"/>
                    </Border>
                    
                    <TextBlock Text="CBT Mock" FontSize="36" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="EXAM MANAGEMENT SYSTEM" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center" LetterSpacing="3" Margin="0,0,0,48"/>
                               
                    <Border Width="60" Height="4" Background="#3B82F6" CornerRadius="2" HorizontalAlignment="Center" Margin="0,0,0,48"/>
                    
                    <TextBlock Text="Proctor Terminal" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Ensure academic integrity with real-time monitoring and advanced session controls." 
                               FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" TextAlignment="Center" LineHeight="22" Width="340"/>
                </StackPanel>
            </Grid>

            <!-- Right Pane (Glass Login) -->
            <Border Grid.Column="1" Background="{DynamicResource PaneBg}" CornerRadius="24" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.2" ShadowDepth="0"/>
                </Border.Effect>
                
                <Grid Margin="48">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Welcome Back" FontSize="28" FontWeight="Black" Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock Text="Sign in to your administrative account" FontSize="14" Foreground="#94A3B8" Margin="0,0,0,40"/>

                        <!-- Error Message -->
                        <Border Background="#10EF4444" CornerRadius="12" Padding="16" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" Margin="0,0,0,24" BorderBrush="#20EF4444" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13" TextWrapping="Wrap" Width="280"/>
                            </StackPanel>
                        </Border>

                        <!-- Input Fields -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="IDENTIFIER" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="4,0,0,8" LetterSpacing="1"/>
                            <Grid Margin="0,0,0,20">
                                <TextBox x:Name="UsernameTextBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputFieldStyle}"/>
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False"/>
                            </Grid>

                            <TextBlock Text="ACCESS KEY" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="4,0,0,8" LetterSpacing="1"/>
                            <Grid>
                                <PasswordBox x:Name="CodeBox" PasswordChanged="PasswordBox_PasswordChanged" Style="{StaticResource PasswordFieldStyle}"/>
                                <TextBox x:Name="VisibleCodeBox" Text="{Binding AccessCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputFieldStyle}" Visibility="Collapsed" TextChanged="VisibleCodeBox_TextChanged"/>
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="TogglePasswordBtn" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0" Cursor="Hand" Click="TogglePasswordBtn_Click">
                                    <TextBlock x:Name="TogglePasswordIcon" Text="&#xED1A;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <Button Command="{Binding LoginCommand}" Style="{StaticResource LoginButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Authenticate" VerticalAlignment="Center"/>
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,0">
                            <TextBlock Text="Need help?" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Button Content="Support Center" Background="Transparent" BorderThickness="0" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" Margin="8,0,0,0" Cursor="Hand" Click="ContactDeveloper_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Header Utilities -->
                    <Button Style="{StaticResource CloseButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-24,-24,0,0" Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
