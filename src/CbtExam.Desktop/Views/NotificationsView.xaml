<UserControl x:Class="CbtExam.Desktop.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Notifications" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" Padding="12" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" DockPanel.Dock="Left"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm:ss}'}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Message}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
