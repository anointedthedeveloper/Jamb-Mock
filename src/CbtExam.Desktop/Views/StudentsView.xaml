<UserControl x:Class="CbtExam.Desktop.Views.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Width="280" HorizontalAlignment="Left"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                <Button Content="Print List" Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}" Background="{StaticResource GreenBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding Students}" SelectedItem="{Binding Selected}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="140"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="14,0,0,0">
                <StackPanel>
                    <TextBlock Text="Manage Student" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Full Name"/>
                    <TextBox Text="{Binding FullName}" Margin="0,4,0,8"/>
                    <TextBlock Text="Student ID"/>
                    <TextBox Text="{Binding StudentId}" Margin="0,4,0,8"/>
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,0,0,8"/>
                    <TextBlock Text="Reset Password"/>
                    <TextBox Text="{Binding NewPassword}" Margin="0,4,0,10"/>
                    <WrapPanel>
                        <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,8"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}" Margin="0,0,8,8"/>
                        <Button Content="Update Password" Command="{Binding PasswordCommand}" Style="{StaticResource PrimaryBtn}" Background="{StaticResource GreenBrush}" Margin="0,0,8,8"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
