<UserControl x:Class="CbtExam.Desktop.Views.ErrorGuideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32,28,32,32">
            
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Error Guide &amp; Troubleshooting" FontSize="24" FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Common issues and solutions for CBT Exam System" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕ Close" Command="{Binding CloseCommand}"
                        Style="{StaticResource PrimaryBtn}" Background="#F1F5F9"
                        Foreground="{DynamicResource TextPrimaryBrush}" Padding="12,8" VerticalAlignment="Center"/>
            </Grid>

            <!-- Quick Actions -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Command="{Binding CheckServerStatusCommand}" 
                                Style="{StaticResource CardBtn}" Margin="0,0,8,0" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Check Server Status" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Grid.Column="1" Command="{Binding ViewLogsCommand}"
                                Style="{StaticResource CardBtn}" Margin="8,0,8,0" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="View Error Logs" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Grid.Column="2" Command="{Binding ResetDatabaseCommand}"
                                Style="{StaticResource CardBtn}" Margin="8,0,0,0" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="&#xE747;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Reset Database" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Common Issues -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Common Issues" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding CommonIssues}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" Padding="16" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                Background="#FEF2F2" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                       Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Solution}" FontSize="12"
                                                       Foreground="#16A34A" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Command="{Binding DataContext.FixIssueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource PrimaryBtn}" Background="#16A34A"
                                                Padding="12,8" VerticalAlignment="Center">
                                            <TextBlock Text="Fix"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- System Status -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="System Status" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                           Foreground="{Binding ServerStatusColor}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Server Status" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ServerStatusText}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16" Margin="8,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                           Foreground="{Binding DatabaseStatusColor}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Database Status" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DatabaseStatusText}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Contact Support -->
            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Need More Help?" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="If you continue to experience issues, please contact technical support." FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <Button Command="{Binding ContactSupportCommand}"
                            Style="{StaticResource PrimaryBtn}" Background="{DynamicResource AccentBrush}"
                            Padding="20,12" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Contact Technical Support" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
