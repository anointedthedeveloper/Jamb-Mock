<UserControl x:Class="CbtExam.Desktop.Views.CreateExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgBrush}">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Create Exam" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Set up a new exam and add questions." FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺  Start Over" Command="{Binding ResetCommand}"
                            Style="{StaticResource PrimaryBtn}" Background="#F1F5F9"
                            Foreground="{StaticResource TextPrimaryBrush}" Padding="14,8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox Content="Advanced Mode" IsChecked="{Binding AdvancedMode}" FontSize="13"
                              Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Status banner -->
            <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding Status, Converter={StaticResource NonEmptyToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="BorderBrush" Value="#FECACA"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Status}" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="#16A34A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- ── Step 1: Exam Details ── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="26" Height="26" CornerRadius="13" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Exam Details" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,12">
                            <TextBlock Text="Title *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding ExamCreated, Converter={StaticResource InvBool}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,12">
                            <TextBlock Text="Subject" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding ExamCreated, Converter={StaticResource InvBool}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Duration (min)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding ExamCreated, Converter={StaticResource InvBool}}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox Content="Shuffle Questions" IsChecked="{Binding ShuffleQuestions}"
                                  IsEnabled="{Binding ExamCreated, Converter={StaticResource InvBool}}"
                                  Margin="0,0,24,0" FontSize="13"/>
                        <CheckBox Content="Shuffle Options" IsChecked="{Binding ShuffleOptions}"
                                  IsEnabled="{Binding ExamCreated, Converter={StaticResource InvBool}}"
                                  FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Save Exam" Command="{Binding SaveExamCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="16,8" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Command="{Binding ResetCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#F1F5F9" Foreground="{StaticResource TextPrimaryBrush}" Padding="16,8"/>
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource DangerBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Advanced Mode: 4 Subjects Configuration -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20" Padding="20"
                    Visibility="{Binding AdvancedMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="26" Height="26" CornerRadius="13" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Advanced Mode: 4 Subjects" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Subject 1 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Subject 1" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedSubject1, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Years (e.g., 2010-2022)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YearRange1, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Questions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding QuestionCount1, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                    </Grid>

                    <!-- Subject 2 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Subject 2" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedSubject2, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Years (e.g., 2010-2022)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YearRange2, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Questions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding QuestionCount2, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                    </Grid>

                    <!-- Subject 3 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Subject 3" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedSubject3, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Years (e.g., 2010-2022)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YearRange3, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Questions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding QuestionCount3, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                    </Grid>

                    <!-- Subject 4 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Subject 4" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedSubject4, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Years (e.g., 2010-2022)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YearRange4, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Questions" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding QuestionCount4, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Generate Advanced Exam" Command="{Binding GenerateExamCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="16,8" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Command="{Binding ResetCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="#F1F5F9" Foreground="{StaticResource TextPrimaryBrush}" Padding="16,8"/>
                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusOk, Converter={StaticResource BoolToColor}}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Step 2: Add Questions (shown after exam saved) ── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20"
                    Visibility="{Binding ExamCreated, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="26" Height="26" CornerRadius="13" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center">
                            <Run Text="Add Questions to "/>
                            <Run Text="{Binding CreatedExamTitle}" Foreground="{StaticResource AccentBrush}"/>
                        </TextBlock>
                        <Border CornerRadius="4" Background="#EFF6FF" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="#2563EB">
                                <Run Text="{Binding Questions.Count, Mode=OneWay}"/><Run Text=" added"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Manual question entry -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Manual Entry" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Question Text *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding QText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Option A *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Opt1, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Option B *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Opt2, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Option C" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Opt3, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Option D" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Opt4, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Correct Answer * (must match an option exactly)" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Correct, UpdateSourceTrigger=PropertyChanged}" Width="260" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <Button Content="＋  Add Question" Command="{Binding AddQuestionCommand}"
                                    Style="{StaticResource SuccessBtn}" Padding="16,8" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- JSON bulk import -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Bulk Import (JSON)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10">
                                <Run Text='Paste a JSON array: [{"questionNumber":1,"text":"...","options":["A","B","C","D"],"correctAnswer":"A"}]'/>
                            </TextBlock>
                            <TextBox Text="{Binding JsonImport, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>
                            <Button Content="⬆  Import JSON" Command="{Binding ImportJsonCommand}"
                                    Style="{StaticResource PrimaryBtn}" Padding="16,8" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Added questions list -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding ExamCreated, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Questions Added" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Border Background="#F8FAFC" CornerRadius="6" Padding="16"
                            Visibility="{Binding Questions.Count, Mode=OneWay, Converter={StaticResource ZeroToVis}}">
                        <TextBlock Text="No questions added yet." FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Questions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="6" BorderBrush="#E2E8F0"
                                        BorderThickness="1" Padding="14,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                Background="#EFF6FF" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding QuestionNumber, Mode=OneWay}" FontSize="12" FontWeight="Bold"
                                                       Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Text, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#16A34A" FontSize="11"/>
                                                <TextBlock Text="{Binding CorrectAnswer, Mode=OneWay}" Foreground="#16A34A"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="4" Background="#F0FDF4"
                                                Padding="8,3" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" Foreground="#16A34A">
                                                <Run Text="{Binding Options.Count, Mode=OneWay}"/><Run Text=" opts"/>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
