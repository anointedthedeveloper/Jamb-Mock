<UserControl x:Class="CbtExam.Desktop.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{DynamicResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Results" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Review student scores and session performance." FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="14,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                            <TextBlock Text="Print"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{StaticResource GreenBrush}" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Session selector -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="18,14" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                              DisplayMemberPath="SessionCode" Width="200" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding SelectedSession.ExamTitle}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Stats row -->
            <UniformGrid Columns="3" Margin="0,0,0,18"
                         Visibility="{Binding Results.Count, Converter={StaticResource IntToVis}}">
                <Border Background="{DynamicResource CardBrush}" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Average Score" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0">
                            <Run Text="{Binding AvgScore}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBrush}" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Passed" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PassCount}" FontSize="32" FontWeight="Bold" Foreground="#16A34A" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBrush}" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Failed" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding FailCount}" FontSize="32" FontWeight="Bold" Foreground="#DC2626" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Results table -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="18">
                <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Student"    Binding="{Binding FullName}"  Width="*"/>
                        <DataGridTextColumn Header="ID"         Binding="{Binding StudentId}" Width="120"/>
                        <DataGridTextColumn Header="Score"      Binding="{Binding Score}"     Width="70"/>
                        <DataGridTextColumn Header="Total"      Binding="{Binding Total}"     Width="70"/>
                        <DataGridTextColumn Header="%"          Binding="{Binding Percentage, StringFormat='{}{0:F0}%'}" Width="80"/>
                        <DataGridTemplateColumn Header="Result" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Passed}" Value="True">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Failed"/>
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Passed}" Value="True">
                                                            <Setter Property="Text" Value="Passed"/>
                                                            <Setter Property="Foreground" Value="#047857"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedAt, StringFormat='HH:mm:ss'}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
