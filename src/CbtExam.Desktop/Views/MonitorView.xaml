<UserControl x:Class="CbtExam.Desktop.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Live Exam Monitor" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SessionInfo, Mode=OneWay}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="10" Background="#1016A34A" BorderBrush="#2016A34A" BorderThickness="1"
                            Padding="14,8" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,0,10,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="Auto-sync Active (5s)" FontSize="12" FontWeight="SemiBold" Foreground="#16A34A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" 
                            Background="{DynamicResource PremiumGradient}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Force Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="CANDIDATES CONNECTED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="{Binding Students.Count, Mode=OneWay}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="SESSION PROGRESS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="84%" FontSize="36" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="SYSTEM HEALTH" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="OPTIMAL" FontSize="36" FontWeight="Black" Foreground="#16A34A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Monitoring Table -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="16,16,0,0" Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Live Candidate Roster" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Width="300" Height="40" Margin="0,0,12,0">
                                    <Grid>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                                        <TextBox Padding="40,8,12,8" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Search active candidates..." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="40,0,0,0" IsHitTestVisible="False" Opacity="0.5"/>
                                    </Grid>
                                </Border>
                                <Button Content="Export CSV" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Padding="12">
                        <DataGrid ItemsSource="{Binding Students, Mode=OneWay}"
                                  Background="Transparent" BorderThickness="0" RowHeight="55" GridLinesVisibility="None"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="CANDIDATE" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource NavActiveBrush}" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding StudentId}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="JOINED" Binding="{Binding JoinedAt, Mode=OneWay, StringFormat='HH:mm:ss'}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="PROGRESS" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding AnsweredCount, StringFormat='{}{0} Answered'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <ProgressBar Value="{Binding AnsweredCount}" Maximum="100" Height="4" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="BATTERY" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8B2;" FontFamily="Segoe MDL2 Assets" Foreground="#16A34A" FontSize="14" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding BatteryLevel, StringFormat='{}{0}%'}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="ALERTS" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Background="#10DC2626" CornerRadius="8" Padding="8,4" Visibility="{Binding TabSwitchCount, Converter={StaticResource IntToVis}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#DC2626" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TabSwitchCount}" Foreground="#DC2626" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="STATUS" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="12,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1016A34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSubmitted, Mode=OneWay}" Value="True">
                                                                <Setter Property="Background" Value="#103B82F6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="IN PROGRESS"/>
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSubmitted, Mode=OneWay}" Value="True">
                                                                    <Setter Property="Text" Value="SUBMITTED"/>
                                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
