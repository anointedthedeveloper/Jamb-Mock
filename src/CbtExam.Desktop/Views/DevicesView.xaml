<UserControl x:Class="CbtExam.Desktop.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Live Devices" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SessionInfo, Mode=OneWay}" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Refresh Nodes" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Stat pills -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
            <Border CornerRadius="16" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24,16" Margin="0,0,16,0" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="TOTAL NODES" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Total, Mode=OneWay}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="16" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource PremiumGradient}" BorderThickness="1"
                    Padding="24,16" MinWidth="180">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="ONLINE NOW" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Online, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#3B82F6" Opacity="0.6" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Table header -->
                <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="14,14,0,0" Padding="0,0,0,0">
                    <Grid Height="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DEVICE / STUDENT" Margin="24,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="STUDENT ID" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="CONNECTED" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="STATUS" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="BATTERY" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Background="Transparent">
                                    <Grid Height="60">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                                            <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource NavActiveBrush}" Margin="0,0,14,0">
                                                <TextBlock Text="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding DeviceName, TargetNullValue='CBT Device Node'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding StudentId}" VerticalAlignment="Center" FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding JoinedAt}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        
                                        <Border Grid.Column="3" CornerRadius="8" Padding="12,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                            <Setter Property="Background" Value="#1016A34A"/>
                                                            <Setter Property="BorderBrush" Value="#3016A34A"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Submitted">
                                                            <Setter Property="Background" Value="#103B82F6"/>
                                                            <Setter Property="BorderBrush" Value="#303B82F6"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Submitted">
                                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xEBB0;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Battery, Converter={StaticResource LatencyToBool}, ConverterParameter=20}" Value="False">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                                <Setter Property="Text" Value="&#xEBAE;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Battery, StringFormat='{}{0}%'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
